# =============================================================================
# Supabase Self-Hosted - Variables de Entorno
# Pulsos Sociales - Infraestructura de Persistencia
# =============================================================================
#
# Copia este archivo a .env y configura tus valores
# cp .env.supabase.example .env
#
# =============================================================================

# =============================================================================
# SECRETS (¡CAMBIA ESTOS VALORES EN PRODUCCIÓN!)
# =============================================================================

# Contraseña de PostgreSQL (mínimo 32 caracteres recomendado)
POSTGRES_PASSWORD=your-super-secret-and-long-postgres-password

# Secreto para JWT (genera uno seguro con: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long

# Secreto para Service Role (genera uno seguro)
SERVICE_ROLE_KEY=your-super-secret-service-role-key

# Secreto para Anon Key (genera uno seguro)
ANON_KEY=your-super-secret-anon-key

# Secreto para base de datos encriptada (opcional)
DB_ENC_KEY=your-super-secret-db-enc-key

# Secreto para Realtime
SECRET_KEY_BASE=your-super-secret-secret-key-base

# =============================================================================
# BASE DE DATOS
# =============================================================================

POSTGRES_USER=postgres
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# =============================================================================
# PUERTOS DE SERVICIOS
# =============================================================================

# Kong API Gateway
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443

# Supabase Studio (UI de administración)
STUDIO_PORT=3000

# =============================================================================
# CONFIGURACIÓN DE AUTENTICACIÓN (GoTrue)
# =============================================================================

# URL pública de la API
API_EXTERNAL_URL=http://localhost:8000

# URL del sitio (frontend)
SITE_URL=http://localhost:5173

# URLs adicionales permitidas para redirección (separadas por comas)
ADDITIONAL_REDIRECT_URLS=http://localhost:3000,http://localhost:5173

# Deshabilitar registro de nuevos usuarios
DISABLE_SIGNUP=false

# Expiración de JWT en segundos
JWT_EXPIRY=3600

# Habilitar registro con email
ENABLE_EMAIL_SIGNUP=true

# Auto-confirmar emails (sin verificación)
MAILER_AUTOCONFIRM=true

# Habilitar usuarios anónimos
ENABLE_ANONYMOUS_USERS=false

# Habilitar registro con teléfono
ENABLE_PHONE_SIGNUP=false

# Auto-confirmar teléfonos
SMS_AUTOCONFIRM=false

# =============================================================================
# CONFIGURACIÓN SMTP (para emails reales)
# =============================================================================
# Descomenta y configura si quieres enviar emails reales
# Si no configuras, los emails se imprimirán en logs

# SMTP_ADMIN_EMAIL=noreply@pulsos-sociales.cl
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu-email@gmail.com
# SMTP_PASS=tu-app-password
# SMTP_SENDER_NAME="Pulsos Sociales"

# =============================================================================
# CONFIGURACIÓN DE ALMACENAMIENTO
# =============================================================================

# Tamaño máximo de archivo (50MB por defecto)
FILE_SIZE_LIMIT=52428800

# Backend de almacenamiento: 'file' o 's3'
STORAGE_BACKEND=file

# Bucket S3 por defecto (si usas S3)
DEFAULT_S3_BUCKET=pulsos-storage

# Configuración S3 (solo si STORAGE_BACKEND=s3)
# S3_PROTOCOL=https
# S3_HOST=s3.amazonaws.com
# S3_PORT=443
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=tu-access-key
# S3_SECRET_ACCESS_KEY=tu-secret-key

# =============================================================================
# CONFIGURACIÓN DE SUPABASE STUDIO
# =============================================================================

STUDIO_DEFAULT_ORGANIZATION=Pulsos Sociales
STUDIO_DEFAULT_PROJECT=pulsos-sociales
SUPABASE_PUBLIC_URL=http://localhost:8000

# API Key de OpenAI (opcional, para features de IA en Studio)
# OPENAI_API_KEY=sk-...

# =============================================================================
# CONFIGURACIÓN DE REALTIME
# =============================================================================

# Máximo de eventos por segundo
MAX_EVENTS_PER_SECOND=100

# Máximo de suscriptores
MAX_SUBSCRIBERS=100000

# Máximo de canales por cliente
MAX_CHANNELS_PER_CLIENT=100

# =============================================================================
# CONFIGURACIÓN DE ANALYTICS (opcional)
# =============================================================================

# LOGFLARE_API_KEY=...
# LOGFLARE_API_URL=...

# =============================================================================
# CONFIGURACIÓN DE IMÁGENES
# =============================================================================

# Habilitar detección de WebP
IMGPROXY_ENABLE_WEBP_DETECTION=true

# =============================================================================
# SCHEMAS DE BASE DE DATOS
# =============================================================================

PGRST_DB_SCHEMAS=public,storage,graphql_public

# =============================================================================
# NOTAS IMPORTANTES
# =============================================================================
#
# 1. GENERAR CLAVES SEGURAS:
#    Para generar claves seguras, usa:
#    openssl rand -base64 32
#
# 2. PRODUCCIÓN:
#    - Cambia TODOS los secretos
#    - Usa HTTPS en API_EXTERNAL_URL y SITE_URL
#    - Configura SMTP real
#    - Considera usar S3 para storage
#    - Habilita backups de PostgreSQL
#
# 3. DESARROLLO:
#    - Los valores por defecto funcionan para desarrollo local
#    - MAILER_AUTOCONFIRM=true evita necesidad de SMTP
#    - STORAGE_BACKEND=file usa disco local
#
# 4. EASYPANEL:
#    - Sube este archivo como Environment Variables
#    - Configura los servicios según docker-compose.supabase.yml
#
# =============================================================================
