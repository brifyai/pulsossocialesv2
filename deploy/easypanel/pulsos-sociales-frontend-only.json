{
  "name": "pulsos-sociales",
  "description": "Pulsos Sociales - Simulación territorial y encuestas sintéticas para Chile",
  "services": [
    {
      "type": "app",
      "name": "pulsos-frontend",
      "source": {
        "type": "git",
        "repo": "https://github.com/brifyai/pulsossocialesv2.git",
        "branch": "main"
      },
      "build": {
        "type": "dockerfile",
        "dockerfile": "Dockerfile",
        "buildArgs": {
          "VITE_MAPTILER_KEY": "orWgcmF4NtAAER2Tgjp2",
          "VITE_SUPABASE_URL": "",
          "VITE_SUPABASE_ANON_KEY": ""
        }
      },
      "deploy": {
        "restartPolicy": "always",
        "healthCheck": {
          "path": "/health",
          "port": 80,
          "initialDelaySeconds": 10,
          "periodSeconds": 10,
          "timeoutSeconds": 5,
          "successThreshold": 1,
          "failureThreshold": 3
        }
      },
      "networking": {
        "containerPort": 80,
        "servicePort": 80
      }
    }
  ]
}
